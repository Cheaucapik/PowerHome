<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/off_white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ================= CALENDAR ================= -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calendar of the week"
            android:textColor="@color/dark_green"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Header mois + flèches -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_month"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="March"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:background="@drawable/edittext_rounded"
                        android:backgroundTint="@color/dark_green"
                        android:padding="8dp"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/btn_prev_2weeks"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="&lt;"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:background="@drawable/edittext_rounded"
                        android:backgroundTint="@color/off_white"
                        android:textColor="@color/black"/>

                    <TextView
                        android:id="@+id/btn_next_2weeks"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="&gt;"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/edittext_rounded"
                        android:backgroundTint="@color/off_white"
                        android:textColor="@color/black"/>
                </LinearLayout>

                <!-- Jours semaine -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <TextView style="@style/dayLabel" android:text="M"/>
                    <TextView style="@style/dayLabel" android:text="T"/>
                    <TextView style="@style/dayLabel" android:text="W"/>
                    <TextView style="@style/dayLabel" android:text="T"/>
                    <TextView style="@style/dayLabel" android:text="F"/>
                    <TextView style="@style/dayLabel" android:text="S"/>
                    <TextView style="@style/dayLabel" android:text="S"/>
                </LinearLayout>

                    <!-- RecyclerView calendrier -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_calendar_days"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:nestedScrollingEnabled="false"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ================= CHOIX CRENEAU (caché jusqu'au clic sur une date) ================= -->

        <LinearLayout
            android:id="@+id/request_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="20dp"
            android:visibility="gone">

            <!-- Titre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choisir un créneau :"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/black"/>

            <!-- Sous-titre "Résumé des données" -->
            <TextView
                android:id="@+id/tv_resume_donnees"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Résumé des données"
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="14dp"
                android:visibility="gone"/>

            <!-- Ligne Date choisie -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_today"
                    android:alpha="0.6"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Date choisie"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:layout_marginStart="10dp"/>

                <TextView
                    android:id="@+id/tv_selected_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--/--"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/black"/>
            </LinearLayout>

            <!-- Ligne Créneau choisi -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    android:alpha="0.6"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Créneau choisi :"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:layout_marginStart="10dp"/>

                <!-- Slots alignés à droite -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tv_slot_morning"
                        style="@style/slotStyle"
                        android:text="7h-12h"/>

                    <TextView
                        android:id="@+id/tv_slot_afternoon"
                        style="@style/slotStyle"
                        android:text="12h-17h"/>

                    <TextView
                        android:id="@+id/tv_slot_evening"
                        style="@style/slotStyle"
                        android:text="17h-22h"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Ligne Bonus éco-coin -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/star_on"
                    android:alpha="0.5"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bonus éco-coin"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:layout_marginStart="10dp"/>

                <TextView
                    android:id="@+id/tv_bonus_ecocoin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/gray"/>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/off_white"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="10dp"/>

            <!-- Sélectionner l'appareil utilisé -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sélectionnez l'appareil utilisé :"
                android:textSize="13sp"
                android:textColor="@color/black"
                android:layout_marginBottom="10dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layout_appliance_icons"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/off_white"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"/>

            <!-- Solde Total -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Solde Total"
                    android:textSize="14sp"
                    android:textColor="@color/black"/>

                <TextView
                    android:id="@+id/tv_total_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/gray"/>
            </LinearLayout>

            <!-- Message d'avertissement créneau saturé -->
            <TextView
                android:id="@+id/tv_warning_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="⚠ Attention, ce créneau est saturé."
                android:textColor="@color/red"
                android:textStyle="bold"
                android:textSize="13sp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>