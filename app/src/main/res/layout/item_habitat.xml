<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp"
    android:background="@drawable/card"
    >

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/nom_habitant_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gaëtan Leclair"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="4dp">

            <TextView
                android:id="@+id/nb_equipements_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4 équipements"
                android:textColor="@color/light_grey_border"
                android:textStyle="italic|bold" />

            <LinearLayout
                android:id="@+id/container_icons_LL"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>

        </LinearLayout>
    </LinearLayout>


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/edittext_rounded"
        android:backgroundTint="@color/dark_green"
        android:padding="5dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Etage"
            android:textColor="@color/white"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:paddingStart="5dp"
            android:id="@+id/floor_tv"
            tools:ignore="RtlSymmetry" />

            <TextView
                android:id="@+id/etage_tv"
                android:layout_width="24dp"
                android:layout_height="25dp"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/white"
                android:textStyle="bold" />

</LinearLayout>

</LinearLayout>
